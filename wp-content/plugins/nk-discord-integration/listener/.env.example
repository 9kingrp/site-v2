# Discord bot token (Bot tab in the Developer Portal).
# Make sure the "Server Members Intent" toggle is ON for this app.
DISCORD_BOT_TOKEN=

# Full URL to the WordPress REST endpoint.
# Find this in wp-admin → Settings → Nine Kings Discord (under "Welcome Channel").
WP_ENDPOINT=https://your-site.example/wp-json/nk-discord/v1/member-joined

# Same value as the "Listener Shared Secret" field in the WP settings page.
WP_SHARED_SECRET=

# Optional: restrict to a single guild. Leave blank to forward joins from any guild the bot is in.
GUILD_ID=
